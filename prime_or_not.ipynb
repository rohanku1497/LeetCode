   "source": [
    "n=49\n",
    "f=0\n",
    "for i in range(2,n):\n",
    "    if n%i == 0:\n",
    "        f=1\n",
    "if f==0:\n",
    "    print('prime')                \n",
    "else:\n",
    "    print('not a prime')   \n"
   ]
  },
  {
   "cell_type": "code",
